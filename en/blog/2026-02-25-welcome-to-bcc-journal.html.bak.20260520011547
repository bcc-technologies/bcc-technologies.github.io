        <script data-bcc-resource-rail>

(function(){
  function esc(value){
    return String(value == null ? "" : value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function iconFor(type){
    const t = String(type || "").toLowerCase();
    if (["music", "resonance", "resonancia"].includes(t)) return "♪";
    if (["book", "libro"].includes(t)) return "▤";
    if (["paper", "article", "articulo", "artículo", "reference", "ref"].includes(t)) return "§";
    if (["tool", "software", "product", "service"].includes(t)) return "◇";
    if (["video"].includes(t)) return "▶";
    if (["dataset", "data"].includes(t)) return "◎";
    return "✦";
  }

  function labelFor(type){
    const t = String(type || "resource").toLowerCase();
    const labels = {
      music: "Resonance",
      resonance: "Resonance",
      resonancia: "Resonance",
      book: "Reading",
      libro: "Reading",
      paper: "Reference",
      article: "Article",
      articulo: "Article",
      "artículo": "Article",
      tool: "Tool",
      software: "Tool",
      product: "Product",
      service: "Service",
      video: "Video",
      dataset: "Dataset",
      data: "Dataset"
    };
    return labels[t] || "Resource";
  }

  function renderResource(resource){
    const type = labelFor(resource.type);
    const title = resource.title || resource.name || "Untitled resource";
    const creator = resource.creator || resource.author || resource.source || "";
    const year = resource.year ? ` · ${esc(resource.year)}` : "";
    const byline = creator ? `<div class="resource-byline">${esc(creator)}${year}</div>` : (resource.year ? `<div class="resource-byline">${esc(resource.year)}</div>` : "");
    const note = resource.note || resource.reason || resource.description || "";
    const linkLabel = resource.linkLabel || "Open";
    const link = resource.url ? `<a class="resource-link" href="${esc(resource.url)}" target="_blank" rel="noopener noreferrer">${esc(linkLabel)} <span aria-hidden="true">↗</span></a>` : "";

    return `
      <article class="resource-card">
        <div class="resource-card-top">
          <span class="resource-icon" aria-hidden="true">${esc(iconFor(resource.type))}</span>
          <div class="resource-card-main">
            <div class="resource-type">${esc(type)}</div>
            <div class="resource-name">${esc(title)}</div>
            ${byline}
          </div>
        </div>
        ${note ? `<p class="resource-note">${esc(note)}</p>` : ""}
        ${link}
      </article>
    `;
  }

  function initResources(){
    const dataEl = document.getElementById("postResourcesData");
    const rail = document.getElementById("postResourceRail");
    const toggle = document.getElementById("resourceRailToggle");
    const panel = document.getElementById("resourceRailPanel");
    const railList = document.getElementById("resourceRailList");
    const mobile = document.getElementById("postResourcesMobile");
    const mobileList = document.getElementById("postResourcesMobileList");

    if (!dataEl || !rail || !railList || !mobile || !mobileList) return;

    let resources = [];
    try {
      resources = JSON.parse(dataEl.textContent || "[]");
    } catch (e) {
      resources = [];
    }

    if (!Array.isArray(resources) || resources.length === 0) return;

    const html = resources.map(renderResource).join("");
    railList.innerHTML = html;
    mobileList.innerHTML = html;
    rail.hidden = false;
    mobile.hidden = false;

    function setOpen(open){
      rail.dataset.open = open ? "true" : "false";
      toggle?.setAttribute("aria-expanded", String(Boolean(open)));
    }

    toggle?.addEventListener("click", () => {
      setOpen(rail.dataset.open !== "true");
    });

    rail.querySelectorAll('[data-action="close-resources"]').forEach(btn => {
      btn.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });

    document.addEventListener("click", (event) => {
      if (rail.dataset.open !== "true") return;
      if (rail.contains(event.target)) return;
      setOpen(false);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initResources);
  } else {
    initResources();
  }
